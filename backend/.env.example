# ═══════════════════════════════════════════════
# ElectaVerse — Environment Variables Template
# Copy this file to backend/.env and fill in values
# ═══════════════════════════════════════════════

# Google Gemini API Key (required for AI features)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq API Key (optional — AI fallback provider)
GROQ_API_KEY=

# Google OAuth Client ID (for Google Sign-In)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Flask secret key (change in production!)
SECRET_KEY=electaverse-secret-key-change-me

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# MySQL Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=electaverse

# Google Cloud Platform
GCP_PROJECT_ID=
GCS_BUCKET_NAME=electaverse-artifacts
CLOUD_LOGGING_ENABLED=false

# Firebase (Spark plan — free)
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=electaverse

